---
import { navLinks, site } from "@/data/site";
const path = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="container-xl">
    <div class="flex items-center justify-between py-6">
      <a href="/" class="flex items-center group" aria-label={site.name}>
        <img src="/logo.png" alt="Myers Group Media" class="h-8 w-auto object-contain transition-opacity duration-300 group-hover:opacity-80" />
      </a>

      <nav class="hidden md:flex items-center gap-1">
        {navLinks.filter(l => l.href !== "/").map((link) => {
          const active = path === link.href || (link.href !== "/" && path.startsWith(link.href));
          return (
            <a
              href={link.href}
              class={`px-4 py-2 font-mono text-[0.72rem] uppercase tracking-[0.18em] transition-colors ${active ? "text-[color:var(--color-accent)]" : "text-[color:var(--color-bone)] hover:text-[color:var(--color-accent)]"}`}
            >
              {link.label}
            </a>
          );
        })}
      </nav>

      <a href="/contact" class="hidden md:inline-flex items-center gap-2 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-[color:var(--color-bone)] hover:text-[color:var(--color-accent)] transition-colors">
        Start a Project
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/></svg>
      </a>

      <button id="mobile-toggle" class="md:hidden text-[color:var(--color-bone)]" aria-label="Menu">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 9h20M4 19h20" stroke="currentColor" stroke-width="1.2"/></svg>
      </button>
    </div>
  </div>
</header>

<div id="mobile-menu" class="fixed inset-0 z-40 bg-[color:var(--color-ink)] hidden flex-col items-center justify-center gap-8">
  {navLinks.map((link) => (
    <a href={link.href} class="display-3 hover:text-[color:var(--color-accent)] transition-colors">{link.label}</a>
  ))}
</div>

<script>
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.classList.remove("flex");
    })
  );
</script>
