---
---
<div class="cursor-dot" id="cursor-dot"></div>
<div class="cursor-ring" id="cursor-ring"></div>

<script>
  const dot = document.getElementById("cursor-dot") as HTMLElement | null;
  const ring = document.getElementById("cursor-ring") as HTMLElement | null;

  if (dot && ring && window.matchMedia("(pointer: fine)").matches) {
    let mx = window.innerWidth / 2, my = window.innerHeight / 2;
    let rx = mx, ry = my;
    let visible = false;

    const show = () => {
      if (!visible) {
        dot.style.opacity = "1";
        ring.style.opacity = "1";
        visible = true;
      }
    };
    const hide = () => {
      dot.style.opacity = "0";
      ring.style.opacity = "0";
      visible = false;
    };

    dot.style.opacity = "0";
    ring.style.opacity = "0";
    dot.style.transition = "opacity 0.3s ease";
    ring.style.transition = "opacity 0.3s ease, width 0.35s var(--ease-out-expo), height 0.35s var(--ease-out-expo), border-color 0.3s ease";

    document.addEventListener("mousemove", (e) => {
      mx = e.clientX;
      my = e.clientY;
      show();
    });
    document.addEventListener("mouseleave", hide);
    document.addEventListener("mousedown", () => ring.classList.add("click"));
    document.addEventListener("mouseup", () => ring.classList.remove("click"));

    function tick() {
      rx += (mx - rx) * 0.2;
      ry += (my - ry) * 0.2;
      dot.style.transform = `translate(${mx}px, ${my}px) translate(-50%, -50%)`;
      ring.style.transform = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`;
      requestAnimationFrame(tick);
    }
    tick();

    // delegate hover detection
    const hoverSelector = "a, button, [role='button'], input, textarea, label, [data-cursor-hover]";
    document.addEventListener("mouseover", (e) => {
      const t = e.target as HTMLElement;
      if (t?.closest?.(hoverSelector)) ring.classList.add("hover");
    });
    document.addEventListener("mouseout", (e) => {
      const t = e.target as HTMLElement;
      if (t?.closest?.(hoverSelector)) ring.classList.remove("hover");
    });
  } else if (dot && ring) {
    dot.style.display = "none";
    ring.style.display = "none";
  }
</script>
