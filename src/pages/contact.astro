---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, services } from "@/data/site";
---

<BaseLayout title="Contact" description="Start a project with Myers Group Media.">
  <section class="container-xl pt-40 pb-20">
    <div class="eyebrow mb-8 inline-flex items-center gap-3">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)]" style="box-shadow: 0 0 0 0 var(--color-accent-glow); animation: pulse 2.4s infinite;"></span>
      Contact · Typically replies within 24h
    </div>
    <h1 class="display-1 max-w-[14ch]">
      <span class="split-line"><span>Let's build</span></span>
      <span class="split-line"><span>something <em class="text-[color:var(--color-accent)]">good</em>.</span></span>
    </h1>
  </section>

  <section class="container-xl py-16 border-t border-[color:var(--color-line)]">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
      <!-- Direct contact -->
      <div class="lg:col-span-4 space-y-12">
        <div>
          <div class="eyebrow mb-3">Email</div>
          <a href={`mailto:${site.email}`} class="text-xl lg:text-2xl text-[color:var(--color-bone)] link-underline">{site.email}</a>
        </div>
        <div>
          <div class="eyebrow mb-3">Location</div>
          <div class="text-xl text-[color:var(--color-bone)]">Mississippi, USA</div>
          <div class="text-[color:var(--color-bone-dim)] mt-1">Working with brands worldwide</div>
        </div>
        <div>
          <div class="eyebrow mb-3">Hours</div>
          <div class="text-xl text-[color:var(--color-bone)]">Mon — Fri, 9–6 CT</div>
        </div>
        <div>
          <div class="eyebrow mb-3">Founded</div>
          <div class="text-xl text-[color:var(--color-bone)]">{site.founded} · by {site.founder}</div>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-8">
        <form id="contact-form" action="/api/contact" method="POST" class="space-y-10" novalidate>
          <div>
            <label for="name" class="eyebrow block mb-3">[ 01 ] Your name</label>
            <input id="name" name="name" type="text" required autocomplete="name" placeholder="Jane Doe" class="field-input" />
          </div>

          <div>
            <label for="email" class="eyebrow block mb-3">[ 02 ] Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" placeholder="you@company.com" class="field-input" />
          </div>

          <div>
            <label for="company" class="eyebrow block mb-3">[ 03 ] Company <span class="text-[color:var(--color-mist)] normal-case">— optional</span></label>
            <input id="company" name="company" type="text" autocomplete="organization" placeholder="Acme, Inc." class="field-input" />
          </div>

          <div>
            <span class="eyebrow block mb-4">[ 04 ] What do you need?</span>
            <div class="flex flex-wrap gap-3" role="group" aria-label="Services">
              {services.map((s) => (
                <label class="cursor-pointer select-none">
                  <input type="checkbox" name="services" value={s.title} class="peer sr-only" />
                  <span class="inline-flex items-center gap-2 px-4 py-2 border border-[color:var(--color-line-bright)] rounded-full font-mono text-xs uppercase tracking-[0.14em] text-[color:var(--color-bone-dim)] transition-all duration-300 hover:border-[color:var(--color-bone-dim)] hover:text-[color:var(--color-bone)] peer-focus-visible:outline peer-focus-visible:outline-1 peer-focus-visible:outline-offset-4 peer-focus-visible:outline-[color:var(--color-accent)] peer-checked:bg-[color:var(--color-accent)] peer-checked:text-[color:var(--color-ink)] peer-checked:border-[color:var(--color-accent)] peer-checked:shadow-[0_6px_20px_-6px_var(--color-accent-glow)]">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="opacity-0 scale-50 transition-all duration-300 peer-checked:opacity-100 peer-checked:scale-100 -ml-1 hidden"><path d="M1 5L4 8L9 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="check-dot w-1.5 h-1.5 rounded-full bg-current opacity-40 transition-opacity"></span>
                    {s.title}
                  </span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label for="message" class="eyebrow block mb-3">[ 05 ] Tell us about your project</label>
            <textarea id="message" name="message" rows="5" required placeholder="What are you trying to build, launch, or grow?" class="field-input resize-none"></textarea>
          </div>

          <div class="flex items-center gap-6 flex-wrap">
            <button type="submit" class="btn-primary" id="submit-btn">
              <span class="btn-label">Send message</span>
              <svg class="btn-icon" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
              <svg class="btn-spinner hidden animate-spin" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" stroke-dasharray="20 40" stroke-linecap="round"/></svg>
            </button>
            <p class="font-mono text-xs text-[color:var(--color-mist)] uppercase tracking-[0.14em]">
              We reply personally — no bots, no tickets.
            </p>
          </div>

          <div id="form-status" class="hidden" role="status" aria-live="polite"></div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Animate check dot to check icon on select */
  input:checked ~ span .check-dot {
    opacity: 1;
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const status = document.getElementById("form-status") as HTMLDivElement | null;
  const label = btn?.querySelector(".btn-label") as HTMLElement | null;
  const icon = btn?.querySelector(".btn-icon") as HTMLElement | null;
  const spinner = btn?.querySelector(".btn-spinner") as HTMLElement | null;

  const setState = (state: "idle" | "loading" | "success" | "error", message?: string) => {
    if (!btn || !label || !icon || !spinner || !status) return;
    if (state === "loading") {
      btn.classList.add("is-loading");
      btn.setAttribute("disabled", "true");
      label.textContent = "Sending...";
      icon.classList.add("hidden");
      spinner.classList.remove("hidden");
      status.classList.add("hidden");
    } else if (state === "success") {
      btn.classList.remove("is-loading");
      btn.removeAttribute("disabled");
      label.textContent = "Sent";
      icon.classList.remove("hidden");
      spinner.classList.add("hidden");
      status.classList.remove("hidden");
      status.className = "font-mono text-xs uppercase tracking-[0.14em] text-[color:var(--color-accent)] border border-[color:var(--color-accent)]/40 bg-[color:var(--color-accent-soft)] px-4 py-3 rounded";
      status.textContent = message || "Message sent — we'll reply within 24 hours.";
    } else if (state === "error") {
      btn.classList.remove("is-loading");
      btn.removeAttribute("disabled");
      label.textContent = "Send message";
      icon.classList.remove("hidden");
      spinner.classList.add("hidden");
      status.classList.remove("hidden");
      status.className = "font-mono text-xs uppercase tracking-[0.14em] text-[#ff6b6b] border border-[#ff6b6b]/40 px-4 py-3 rounded";
      status.textContent = message || "Something went wrong. Email us directly.";
    } else {
      btn.classList.remove("is-loading");
      btn.removeAttribute("disabled");
      label.textContent = "Send message";
      icon.classList.remove("hidden");
      spinner.classList.add("hidden");
      status.classList.add("hidden");
    }
  };

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    setState("loading");
    try {
      const data = new FormData(form);
      const res = await fetch("/api/contact", { method: "POST", body: data });
      if (!res.ok) throw new Error("Network");
      setState("success");
      form.reset();
    } catch (err) {
      setState("error");
    }
  });
</script>
