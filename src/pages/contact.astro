---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, services } from "@/data/site";
---

<BaseLayout title="Contact" description="Start a project with Myers Group Media.">
  <section class="container-xl pt-40 pb-20">
    <div class="eyebrow mb-8">Contact</div>
    <h1 class="display-1 max-w-[14ch]">
      <span class="split-line"><span>Let's build</span></span>
      <span class="split-line"><span>something <em class="font-serif italic font-normal text-[color:var(--color-accent)]">good</em>.</span></span>
    </h1>
  </section>

  <section class="container-xl py-16 border-t border-[color:var(--color-line)]">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
      <!-- Direct contact -->
      <div class="lg:col-span-4 space-y-12">
        <div>
          <div class="eyebrow mb-3">Email</div>
          <a href={`mailto:${site.email}`} class="text-xl lg:text-2xl text-[color:var(--color-bone)] hover:text-[color:var(--color-accent)] transition-colors">{site.email}</a>
        </div>
        <div>
          <div class="eyebrow mb-3">Location</div>
          <div class="text-xl text-[color:var(--color-bone)]">Mississippi, USA</div>
          <div class="text-[color:var(--color-bone-dim)] mt-1">Working with brands worldwide</div>
        </div>
        <div>
          <div class="eyebrow mb-3">Hours</div>
          <div class="text-xl text-[color:var(--color-bone)]">Mon — Fri, 9–6 CT</div>
        </div>
        <div>
          <div class="eyebrow mb-3">Founded</div>
          <div class="text-xl text-[color:var(--color-bone)]">{site.founded} · by {site.founder}</div>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-8">
        <form action="/api/contact" method="POST" class="space-y-10">
          <div>
            <label for="name" class="eyebrow block mb-3">[ 01 ] Your name</label>
            <input id="name" name="name" type="text" required class="w-full bg-transparent border-b border-[color:var(--color-line)] py-3 text-xl text-[color:var(--color-bone)] focus:border-[color:var(--color-accent)] focus:outline-none transition-colors" />
          </div>

          <div>
            <label for="email" class="eyebrow block mb-3">[ 02 ] Email</label>
            <input id="email" name="email" type="email" required class="w-full bg-transparent border-b border-[color:var(--color-line)] py-3 text-xl text-[color:var(--color-bone)] focus:border-[color:var(--color-accent)] focus:outline-none transition-colors" />
          </div>

          <div>
            <label for="company" class="eyebrow block mb-3">[ 03 ] Company</label>
            <input id="company" name="company" type="text" class="w-full bg-transparent border-b border-[color:var(--color-line)] py-3 text-xl text-[color:var(--color-bone)] focus:border-[color:var(--color-accent)] focus:outline-none transition-colors" />
          </div>

          <div>
            <label class="eyebrow block mb-4">[ 04 ] What do you need?</label>
            <div class="flex flex-wrap gap-3">
              {services.map((s) => (
                <label class="cursor-pointer">
                  <input type="checkbox" name="services" value={s.title} class="peer sr-only" />
                  <span class="inline-block px-4 py-2 border border-[color:var(--color-line)] rounded-full font-mono text-xs uppercase tracking-[0.14em] text-[color:var(--color-bone-dim)] peer-checked:bg-[color:var(--color-accent)] peer-checked:text-[color:var(--color-ink)] peer-checked:border-[color:var(--color-accent)] transition-all">{s.title}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label for="message" class="eyebrow block mb-3">[ 05 ] Tell us about your project</label>
            <textarea id="message" name="message" rows="5" required class="w-full bg-transparent border-b border-[color:var(--color-line)] py-3 text-xl text-[color:var(--color-bone)] focus:border-[color:var(--color-accent)] focus:outline-none transition-colors resize-none"></textarea>
          </div>

          <button type="submit" class="btn-primary">
            Send message
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
