---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Marquee from "@/components/Marquee.astro";
import HeroCanvas from "@/components/HeroCanvas.tsx";
import { site, services, portfolio } from "@/data/site";

const featuredWork = portfolio.slice(0, 4);
---

<BaseLayout>
  <!-- ======================= HERO ======================= -->
  <section class="relative min-h-screen flex flex-col justify-end overflow-hidden">
    <HeroCanvas client:load />

    <!-- top meta strip -->
    <div class="absolute top-28 left-0 right-0">
      <div class="container-xl flex justify-between items-center">
        <div class="eyebrow">Est. {site.founded} · Mississippi · Worldwide</div>
        <div class="eyebrow hidden md:block">N 34.7° / W 88.9°</div>
      </div>
    </div>

    <div class="container-xl pb-24 lg:pb-32 relative">
      <div class="eyebrow mb-8 reveal">A digital agency for the algorithm age</div>
      <h1 class="display-1 max-w-[18ch] mb-12">
        <span class="split-line"><span>We design,</span></span>
        <span class="split-line"><span>build & grow</span></span>
        <span class="split-line"><span><em class="font-serif italic font-normal text-[color:var(--color-accent)]">brands</em> that</span></span>
        <span class="split-line"><span>dominate online.</span></span>
      </h1>

      <div class="flex flex-col sm:flex-row gap-4 mb-16 reveal">
        <a href="/contact" class="btn-primary">
          Start a project
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
        </a>
        <a href="/work" class="btn-ghost">See our work</a>
      </div>

      <!-- Stats strip -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 pt-12 border-t border-[color:var(--color-line)]">
        {site.stats.map((s) => (
          <div class="reveal">
            <div class="display-3 font-display text-[color:var(--color-bone)]">{s.value}</div>
            <div class="eyebrow mt-2">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================= MARQUEE ======================= -->
  <Marquee items={["Web Design", "Software", "Social Media", "Advertising", "SEO", "App Design", "Branding"]} />

  <!-- ======================= INTRO ======================= -->
  <section class="container-xl py-32 lg:py-48">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-3">
        <div class="eyebrow sticky top-32">[ 01 ] What we do</div>
      </div>
      <div class="lg:col-span-9">
        <h2 class="display-2 mb-12 reveal">
          We're a full-service digital agency that has spent <em class="font-serif italic text-[color:var(--color-accent)]">eighteen years</em> figuring out how to grow brands online — and we've gotten very good at it.
        </h2>
        <p class="text-lg lg:text-xl text-[color:var(--color-bone-dim)] max-w-2xl reveal">
          From local service businesses to statewide media networks, we build the website, run the ads, manage the socials, and write the software. One team. One bill. One throat to choke.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================= SERVICES ======================= -->
  <section class="container-xl py-24 border-t border-[color:var(--color-line)]">
    <div class="flex justify-between items-end mb-16">
      <div>
        <div class="eyebrow mb-4">[ 02 ] Capabilities</div>
        <h2 class="display-2 max-w-[14ch]">Six services. <em class="font-serif italic text-[color:var(--color-accent)]">One</em> system.</h2>
      </div>
      <a href="/services" class="link-arrow hidden md:inline-flex">
        All services
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
      </a>
    </div>

    <div class="border-t border-[color:var(--color-line)]">
      {services.map((s) => (
        <a href={`/services/${s.slug}`} class="group block border-b border-[color:var(--color-line)] py-8 lg:py-10 transition-colors hover:bg-[color:var(--color-ink-2)]">
          <div class="container-xl !px-0 grid grid-cols-12 gap-4 items-center">
            <div class="col-span-2 lg:col-span-1 font-mono text-sm text-[color:var(--color-mist)]">{s.number}</div>
            <div class="col-span-10 lg:col-span-5">
              <div class="display-3 group-hover:text-[color:var(--color-accent)] transition-colors duration-500">{s.title}</div>
            </div>
            <div class="hidden lg:block lg:col-span-5 text-[color:var(--color-bone-dim)]">{s.short}</div>
            <div class="hidden lg:flex lg:col-span-1 justify-end">
              <svg width="20" height="20" viewBox="0 0 14 14" fill="none" class="transition-transform duration-500 group-hover:translate-x-2 group-hover:text-[color:var(--color-accent)]"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.2"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ======================= WORK ======================= -->
  <section class="container-xl py-32 lg:py-48">
    <div class="flex justify-between items-end mb-16">
      <div>
        <div class="eyebrow mb-4">[ 03 ] Selected work</div>
        <h2 class="display-2 max-w-[18ch]">Brands we've <em class="font-serif italic text-[color:var(--color-accent)]">launched</em> and grown.</h2>
      </div>
      <a href="/work" class="link-arrow hidden md:inline-flex">
        All work
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-6 lg:gap-10">
      {featuredWork.map((p, i) => (
        <a href={p.url} target="_blank" rel="noopener" class={`group block reveal ${i % 2 === 1 ? "md:translate-y-16" : ""}`}>
          <div class="aspect-[4/3] bg-[color:var(--color-ink-2)] border border-[color:var(--color-line)] overflow-hidden relative">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="display-3 text-[color:var(--color-line)] group-hover:text-[color:var(--color-accent)] transition-colors duration-700">{p.name}</div>
            </div>
            <div class="absolute top-4 left-4 right-4 flex justify-between font-mono text-[0.7rem] uppercase tracking-[0.15em] text-[color:var(--color-mist)]">
              <span>{p.category}</span>
              <span>{p.year}</span>
            </div>
            <div class="absolute bottom-4 left-4 right-4 flex justify-between items-end">
              <span class="font-mono text-[0.7rem] uppercase tracking-[0.15em] text-[color:var(--color-bone-dim)]">{p.domain}</span>
              <svg width="18" height="18" viewBox="0 0 14 14" fill="none" class="text-[color:var(--color-bone-dim)] transition-all duration-500 group-hover:text-[color:var(--color-accent)] group-hover:translate-x-1 group-hover:-translate-y-1"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.2"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ======================= CTA ======================= -->
  <section class="container-xl py-32 border-t border-[color:var(--color-line)]">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-3">
        <div class="eyebrow">[ 04 ] Next move</div>
      </div>
      <div class="lg:col-span-9">
        <h2 class="display-2 mb-12 reveal">
          You bring the <em class="font-serif italic text-[color:var(--color-accent)]">ambition</em>. We'll bring the eighteen years of getting it right.
        </h2>
        <a href="/contact" class="btn-primary">
          Let's talk
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
