---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { portfolio } from "@/data/site";
---

<BaseLayout title="Work" description="Selected work from Myers Group Media — websites, apps, and brands we've designed and grown.">
  <section class="container-xl pt-40 pb-20">
    <div class="eyebrow mb-8">Selected work</div>
    <h1 class="display-1 max-w-[18ch]">
      <span class="split-line"><span>Brands we've</span></span>
      <span class="split-line"><span><em class="font-serif italic font-normal text-[color:var(--color-accent)]">launched</em>,</span></span>
      <span class="split-line"><span>built, and grown.</span></span>
    </h1>
  </section>

  <section class="border-t border-[color:var(--color-line)]">
    {portfolio.map((p, i) => (
      <a href={p.url} target="_blank" rel="noopener" class="group block border-b border-[color:var(--color-line)] py-16 lg:py-32 transition-colors hover:bg-[color:var(--color-ink-2)]">
        <div class="container-xl">
          <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
            <div class={`lg:col-span-7 ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
              <div class="aspect-[16/10] bg-[color:var(--color-ink-2)] border border-[color:var(--color-line)] overflow-hidden relative group-hover:border-[color:var(--color-accent)] transition-colors duration-500 shadow-2xl">
                {p.image && <img src={p.image} alt={p.name} class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-1000 group-hover:scale-105" />}
              </div>
            </div>
            
            <div class={`lg:col-span-5 ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
              <div class="flex items-center gap-4 mb-8">
                <span class="font-mono text-sm text-[color:var(--color-mist)]">0{i + 1}</span>
                <span class="h-px bg-[color:var(--color-line)] flex-1"></span>
                <svg width="24" height="24" viewBox="0 0 14 14" fill="none" class="text-[color:var(--color-mist)] transition-transform duration-500 group-hover:text-[color:var(--color-accent)] group-hover:translate-x-1 group-hover:-translate-y-1"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.2"/></svg>
              </div>
              
              <h2 class="display-3 group-hover:text-[color:var(--color-accent)] transition-colors duration-500 mb-2">{p.name}</h2>
              <div class="font-mono text-xs uppercase tracking-[0.15em] text-[color:var(--color-bone-dim)] mb-8">{p.domain}</div>
              
              <p class="text-lg text-[color:var(--color-bone-dim)] mb-10">{p.description}</p>
              
              <div class="grid grid-cols-2 gap-8 pt-8 border-t border-[color:var(--color-line)]">
                <div>
                  <div class="eyebrow mb-2">Category & Year</div>
                  <div class="text-[color:var(--color-bone)]">{p.category} — {p.year}</div>
                </div>
                <div>
                  <div class="eyebrow mb-2">Services</div>
                  <ul class="space-y-1">
                    {p.services.map((s) => <li class="text-sm text-[color:var(--color-bone-dim)]">{s}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </a>
    ))}
  </section>

  <section class="container-xl py-32">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <div class="eyebrow">Want to be next?</div>
      </div>
      <div class="lg:col-span-8">
        <h2 class="display-2 mb-8 reveal">Tell us what you're trying to build.</h2>
        <a href="/contact" class="btn-primary">Start a project</a>
      </div>
    </div>
  </section>
</BaseLayout>
