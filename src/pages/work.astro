---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { portfolio } from "@/data/site";
---

<BaseLayout title="Work" description="Selected work from Myers Group Media — websites, apps, and brands we've designed and grown.">
  <section class="container-xl pt-40 pb-20">
    <div class="eyebrow mb-8">Selected work</div>
    <h1 class="display-1 max-w-[18ch]">
      <span class="split-line"><span>Brands we've</span></span>
      <span class="split-line"><span><em class="font-serif italic font-normal text-[color:var(--color-accent)]">launched</em>,</span></span>
      <span class="split-line"><span>built, and grown.</span></span>
    </h1>
  </section>

  <section class="border-t border-[color:var(--color-line)]">
    {portfolio.map((p, i) => (
      <a href={p.url} target="_blank" rel="noopener" class="group block border-b border-[color:var(--color-line)] py-12 lg:py-20 transition-colors hover:bg-[color:var(--color-ink-2)]">
        <div class="container-xl">
          <div class="grid grid-cols-12 gap-6 items-center">
            <div class="col-span-2 md:col-span-1 font-mono text-sm text-[color:var(--color-mist)]">0{i + 1}</div>
            <div class="col-span-10 md:col-span-5">
              <h2 class="display-2 group-hover:text-[color:var(--color-accent)] transition-colors duration-500">{p.name}</h2>
              <div class="mt-3 font-mono text-xs uppercase tracking-[0.15em] text-[color:var(--color-mist)]">{p.domain}</div>
            </div>
            <div class="hidden md:block md:col-span-3">
              <div class="eyebrow mb-2">Category</div>
              <div class="text-[color:var(--color-bone)]">{p.category}</div>
              <div class="eyebrow mt-4 mb-2">Year</div>
              <div class="text-[color:var(--color-bone)]">{p.year}</div>
            </div>
            <div class="hidden md:block md:col-span-2">
              <div class="eyebrow mb-2">Services</div>
              <ul class="space-y-1">
                {p.services.map((s) => <li class="text-sm text-[color:var(--color-bone-dim)]">{s}</li>)}
              </ul>
            </div>
            <div class="hidden md:flex md:col-span-1 justify-end">
              <svg width="28" height="28" viewBox="0 0 14 14" fill="none" class="text-[color:var(--color-mist)] transition-all duration-500 group-hover:text-[color:var(--color-accent)] group-hover:translate-x-2 group-hover:-translate-y-2"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.2"/></svg>
            </div>
            <div class="col-span-12 mt-6 md:mt-4 md:col-start-2">
              <p class="text-[color:var(--color-bone-dim)] max-w-3xl">{p.description}</p>
            </div>
          </div>
        </div>
      </a>
    ))}
  </section>

  <section class="container-xl py-32">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <div class="eyebrow">Want to be next?</div>
      </div>
      <div class="lg:col-span-8">
        <h2 class="display-2 mb-8 reveal">Tell us what you're trying to build.</h2>
        <a href="/contact" class="btn-primary">Start a project</a>
      </div>
    </div>
  </section>
</BaseLayout>
