---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { services } from "@/data/site";
---

<BaseLayout title="Services" description="Six services. One system. Web design, app design, social media, software, advertising, and SEO.">
  <section class="container-xl pt-40 pb-20">
    <div class="eyebrow mb-8">Services</div>
    <h1 class="display-1 max-w-[16ch]">
      <span class="split-line"><span>Six services.</span></span>
      <span class="split-line"><span><em class="text-[color:var(--color-accent)]">One</em> integrated</span></span>
      <span class="split-line"><span>growth system.</span></span>
    </h1>
  </section>

  <section class="border-t border-[color:var(--color-line)]">
    {services.map((s) => (
      <a href={`/services/${s.slug}`} class="group relative block border-b border-[color:var(--color-line)] py-16 lg:py-24 transition-colors duration-500 hover:bg-[color:var(--color-ink-2)]">
        <span class="absolute left-0 top-0 bottom-0 w-px bg-[color:var(--color-accent)] origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"></span>
        <div class="container-xl">
          <div class="grid grid-cols-12 gap-6 items-start">
            <div class="col-span-12 md:col-span-1 font-mono text-sm text-[color:var(--color-mist)] group-hover:text-[color:var(--color-accent)] transition-colors duration-500">{s.number}</div>
            <div class="col-span-12 md:col-span-6">
              <h2 class="display-2 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:translate-x-3 group-hover:text-[color:var(--color-accent)]">{s.title}</h2>
            </div>
            <div class="col-span-12 md:col-span-5">
              <p class="text-lg text-[color:var(--color-bone-dim)] mb-6 leading-relaxed">{s.description}</p>
              <div class="link-arrow">
                Explore
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
              </div>
            </div>
          </div>
        </div>
      </a>
    ))}
  </section>

  <section class="container-xl py-32">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <div class="eyebrow">One team. One bill.</div>
      </div>
      <div class="lg:col-span-8">
        <h2 class="display-2 mb-8 reveal max-w-[22ch]">Hire us for <em class="text-[color:var(--color-accent)]">one thing</em>. Or hire us to run everything.</h2>
        <a href="/contact" class="btn-primary">
          Start a project
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
