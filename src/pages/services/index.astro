---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { services } from "@/data/site";
---

<BaseLayout title="Services" description="Six services. One system. Web design, app design, social media, software, advertising, and SEO.">
  <section class="container-xl pt-40 pb-20">
    <div class="eyebrow mb-8">Services</div>
    <h1 class="display-1 max-w-[16ch]">
      <span class="split-line"><span>Six services.</span></span>
      <span class="split-line"><span><em class="font-serif italic font-normal text-[color:var(--color-accent)]">One</em> integrated</span></span>
      <span class="split-line"><span>growth system.</span></span>
    </h1>
  </section>

  <section class="border-t border-[color:var(--color-line)]">
    {services.map((s) => (
      <a href={`/services/${s.slug}`} class="group block border-b border-[color:var(--color-line)] py-16 lg:py-24 transition-colors hover:bg-[color:var(--color-ink-2)]">
        <div class="container-xl">
          <div class="grid grid-cols-12 gap-6 items-start">
            <div class="col-span-12 md:col-span-1 font-mono text-sm text-[color:var(--color-mist)]">{s.number}</div>
            <div class="col-span-12 md:col-span-6">
              <h2 class="display-2 group-hover:text-[color:var(--color-accent)] transition-colors duration-500">{s.title}</h2>
            </div>
            <div class="col-span-12 md:col-span-5">
              <p class="text-lg text-[color:var(--color-bone-dim)] mb-6">{s.description}</p>
              <div class="link-arrow">
                Explore
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
              </div>
            </div>
          </div>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
