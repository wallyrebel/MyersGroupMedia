---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const all = await getCollection("journal", ({ data }) => !data.draft);
const posts = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" });
---

<BaseLayout title="Journal" description="Field notes from Myers Group Media on web design, marketing, social, and digital growth.">
  <section class="container-xl pt-40 pb-20">
    <div class="eyebrow mb-8">Journal</div>
    <h1 class="display-1 max-w-[16ch]">
      <span class="split-line"><span>Field notes</span></span>
      <span class="split-line"><span>from <em class="font-serif italic font-normal text-[color:var(--color-accent)]">eighteen</em></span></span>
      <span class="split-line"><span>years online.</span></span>
    </h1>
  </section>

  <section class="border-t border-[color:var(--color-line)]">
    {posts.length === 0 && (
      <div class="container-xl py-32 text-center">
        <p class="display-3 text-[color:var(--color-bone-dim)] mb-8">No posts yet. Check back soon.</p>
        <a href="/contact" class="link-arrow">
          Drop us a line
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
        </a>
      </div>
    )}
    {posts.map((post, i) => (
      <a href={`/journal/${post.id}`} class="group relative block border-b border-[color:var(--color-line)] py-12 lg:py-16 transition-colors duration-500 hover:bg-[color:var(--color-ink-2)]">
        <span class="absolute left-0 top-0 bottom-0 w-px bg-[color:var(--color-accent)] origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"></span>
        <div class="container-xl">
          <div class="grid grid-cols-12 gap-6 items-start">
            <div class="col-span-2 md:col-span-1 font-mono text-sm text-[color:var(--color-mist)] group-hover:text-[color:var(--color-accent)] transition-colors">{String(i + 1).padStart(2, "0")}</div>
            <div class="col-span-10 md:col-span-2 font-mono text-xs uppercase tracking-[0.15em] text-[color:var(--color-mist)]">
              {fmtDate(post.data.date)}
            </div>
            <div class="col-span-12 md:col-span-7">
              <h2 class="display-3 group-hover:text-[color:var(--color-accent)] transition-colors duration-500 mb-3">{post.data.title}</h2>
              <p class="text-[color:var(--color-bone-dim)] max-w-2xl leading-relaxed">{post.data.excerpt}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {post.data.tags.slice(0, 4).map((t) => (
                  <span class="font-mono text-[0.65rem] uppercase tracking-[0.14em] text-[color:var(--color-mist)] border border-[color:var(--color-line)] px-2.5 py-1 rounded-full">{t}</span>
                ))}
              </div>
            </div>
            <div class="hidden md:flex md:col-span-2 justify-end">
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-[color:var(--color-line-bright)] group-hover:border-[color:var(--color-accent)] group-hover:bg-[color:var(--color-accent)] transition-all duration-500">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-[color:var(--color-mist)] transition-all duration-500 group-hover:text-[color:var(--color-ink)] group-hover:translate-x-0.5 group-hover:-translate-y-0.5"><path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.4"/></svg>
              </span>
            </div>
          </div>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
